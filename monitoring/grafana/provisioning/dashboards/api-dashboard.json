{
    "id": null,
    "title": "API Incident Dashboard",
    "uid": "api-incident-dashboard",
    "tags": [
        "api",
        "incidents",
        "sre"
    ],
    "timezone": "browser",
    "schemaVersion": 37,
    "version": 1,
    "refresh": "10s",
    "panels": [
        {
            "id": 1,
            "type": "stat",
            "title": "API Health Status",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "api_health_status",
                    "legendFormat": "Health",
                    "datasource": "Prometheus"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": 0
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    },
                    "mappings": [
                        {
                            "options": {
                                "0": {
                                    "text": "UNHEALTHY"
                                },
                                "1": {
                                    "text": "HEALTHY"
                                }
                            },
                            "type": "value"
                        }
                    ]
                }
            }
        },
        {
            "id": 2,
            "type": "stat",
            "title": "Total HTTP Errors",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 0
            },
            "targets": [
                {
                    "expr": "sum(http_errors_total)",
                    "legendFormat": "Errors",
                    "datasource": "Prometheus"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": 0
                            },
                            {
                                "color": "yellow",
                                "value": 5
                            },
                            {
                                "color": "red",
                                "value": 20
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 3,
            "type": "stat",
            "title": "Total Requests",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "sum(http_requests_total)",
                    "legendFormat": "Requests",
                    "datasource": "Prometheus"
                }
            ]
        },
        {
            "id": 4,
            "type": "stat",
            "title": "Error Rate %",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 0
            },
            "targets": [
                {
                    "expr": "sum(http_errors_total) / sum(http_requests_total) * 100",
                    "legendFormat": "Error %",
                    "datasource": "Prometheus"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": 0
                            },
                            {
                                "color": "yellow",
                                "value": 20
                            },
                            {
                                "color": "red",
                                "value": 40
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 5,
            "type": "timeseries",
            "title": "HTTP Errors Over Time",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 4
            },
            "targets": [
                {
                    "expr": "rate(http_errors_total[1m])",
                    "legendFormat": "Error Rate",
                    "datasource": "Prometheus"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "fixedColor": "red",
                        "mode": "fixed"
                    }
                }
            }
        },
        {
            "id": 6,
            "type": "timeseries",
            "title": "Request Volume",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 4
            },
            "targets": [
                {
                    "expr": "rate(http_requests_total[1m])",
                    "legendFormat": "{{route}} {{status_code}}",
                    "datasource": "Prometheus"
                }
            ]
        },
        {
            "id": 7,
            "type": "timeseries",
            "title": "API Health Status Over Time",
            "gridPos": {
                "h": 6,
                "w": 24,
                "x": 0,
                "y": 12
            },
            "targets": [
                {
                    "expr": "api_health_status",
                    "legendFormat": "Health Status (1=OK, 0=FAIL)",
                    "datasource": "Prometheus"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": 0
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    }
                }
            }
        }
    ]
}