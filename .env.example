# AI-Powered Incident Detection System — Environment Variables
# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# # ── OpenAI ──────────────────────────────────────────────────────────────────
# # Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# ── GitHub Integration ────────────────────────────────────────────────────────
# Create a Personal Access Token at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username_here
GITHUB_REPO=your_repo_name_here

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/incidents

# ── Email Notifications (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
NOTIFICATION_EMAILS=your@email.com
