# # ─── AI-Powered Incident Detection System — Environment Variables ──────────────
# # Copy this file to .env and fill in your values
# # Run: cp .env.example .env

# # ── OpenAI ──────────────────────────────────────────────────────────────────
# # Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# # ── GitHub Integration ────────────────────────────────────────────────────────
# # Create a Personal Access Token at: https://github.com/settings/tokens
# # Required scopes: repo (to create issues)
# GITHUB_TOKEN=your_github_token_here

# # Your GitHub username or organization name
# GITHUB_OWNER=your_github_username_here

# # The repository where issues will be created (must exist)
# GITHUB_REPO=your_repo_name_here

# # ── MongoDB ────────────────────────────────────────────────────────────────────
# # Automatically configured via docker-compose; only change if running externally
# MONGO_URI=mongodb://mongo:27017/incidents
